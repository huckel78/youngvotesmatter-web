RewriteEngine On

# 1. Remover la extensión .php de la URL visible al usuario
# Si el usuario escribe /contacto.php, lo redirige a /contacto
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L]

# 2. Mapear internamente la URL limpia al archivo .php
# Si el usuario entra a /contacto, el servidor usa contacto.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*?)/?$ $1.php [L]
